# Supabase
# Get these from Supabase Dashboard > Project Settings > API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-secret-key

# Instagram / Meta App
# Get these from Meta for Developers > Your App > App Settings.
NEXT_PUBLIC_INSTAGRAM_APP_ID=123456789012345
INSTAGRAM_APP_ID=123456789012345
INSTAGRAM_APP_SECRET=your-instagram-app-secret

# Must match the redirect URI configured in your Meta app.
NEXT_PUBLIC_INSTAGRAM_REDIRECT_URI=https://your-domain.com/api/instagram/callback

# Any random string you choose, then use the same value in Meta webhook setup.
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=your-instagram-webhook-verify-token

# AI Gateway / Auto Reply
# Any random secret shared between your app and AI gateway.
GATEWAY_SECRET=your-ai-gateway-secret

# Internal API Hooks
# Any random secret used to protect internal API endpoints or cron hooks.
API_SECRET_KEY=your-internal-api-secret

# Instagram comment automation limits
INSTAGRAM_COMMENT_COOLDOWN_MINUTES=2
INSTAGRAM_COMMENT_AUTOMATION_HOURLY_LIMIT=120
INSTAGRAM_COMMENT_AUTOMATION_DAILY_LIMIT=1000
